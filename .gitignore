# Environments
.env
.venv
env/
venv/
ENV/
.condarc
.mamba_env
.mamba_env/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
*.egg-info/
*.egg
.eggs/
.pytest_cache/
.ruff_cache/

# Jupyter
.ipynb_checkpoints
.jupyter_local

# Editors / tooling
.vscode/
.obsidian/

# Claude Code (local-only permissions and session state)
.claude/

# Data — raw / processed / external / archive payloads are NOT tracked by default.
# Never commit large or non-shareable data. Track only small, shareable curated
# tables, explicitly, once a consumer artefact stabilises (git add -f or a
# narrower un-ignore rule). archive/ is per-run operational logs, never a deliverable.
data/raw/*
data/processed/*
data/external/*
data/archive/*
!data/**/.gitkeep

# Quantum-chemistry + TS-search scratch (Psi4 / ORCA / xTB / autodE)
logs/*
*.wfn
*.fchk
*.gbw
*.molden
*.cube
*.opt
*.log
*.out
*.xyz
*.clean
*.dat
xtbopt.*
xtbrestart.*
autode_calculations/
*_autode/
# ...but the fixed-amine reference cache is a committed asset, not scratch -- keep its
# geometry sidecars (the *.xyz rule above would otherwise drop them).
!assets/amine_ref/*.xyz
# PCMSolver scratch (written to CWD by the PCM single point)
PEDRA.OUT*
cavity.off*
cavity.npz
